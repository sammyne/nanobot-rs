#!/bin/bash

# 颜色定义
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

echo "🔍 运行 pre-commit 检查..."

# 1. 检查代码格式
echo "  → 检查代码格式 (cargo +nightly fmt --check)..."
if ! cargo +nightly fmt --check; then
    echo -e "${RED}❌ 代码格式检查失败${NC}"
    echo -e "${YELLOW}提示: 运行 'cargo +nightly fmt' 自动修复格式问题${NC}"
    exit 1
fi
echo -e "${GREEN}  ✓ 代码格式检查通过${NC}"

# 2. 运行 Clippy 检查
echo "  → 运行 Clippy 检查 (cargo clippy -- -D warnings -D clippy::uninlined_format_args)..."
if ! cargo clippy -- -D warnings -D clippy::uninlined_format_args; then
    echo -e "${RED}❌ Clippy 检查失败${NC}"
    echo -e "${YELLOW}提示: 请修复上述警告后再提交${NC}"
    exit 1
fi
echo -e "${GREEN}  ✓ Clippy 检查通过${NC}"

echo -e "${GREEN}✅ 所有检查通过，准备提交${NC}"
exit 0
